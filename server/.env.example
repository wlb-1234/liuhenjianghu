# ===========================================
# 流痕江湖 - 环境变量配置
# ===========================================

# 数据库配置
DATABASE_URL=postgresql://user:password@host:5432/liuhenjianghu?sslmode=require

# JWT 密钥（请修改为安全的随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 服务器配置
PORT=9091
NODE_ENV=development
BASE_URL=http://localhost:9091

# ===========================================
# IPFS 配置（去中心化存储）
# ===========================================
# 请到 https://app.pinata.cloud/ 注册免费账号获取

# Pinata API Key（用于上传文件到 IPFS）
PINATA_API_KEY=your-pinata-api-key

# Pinata API Secret
PINATA_API_SECRET=your-pinata-api-secret

# IPFS 公开网关（可选项，使用默认的 Pinata 网关）
# IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
# PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/

# ===========================================
# 支付配置（可选）
# ===========================================

# 微信支付
# WECHAT_APP_ID=your-wechat-app-id
# WECHAT_MCH_ID=your-merchant-id
# WECHAT_API_KEY=your-wechat-api-key

# 支付宝
# ALIPAY_APP_ID=your-alipay-app-id
# ALIPAY_PRIVATE_KEY=your-alipay-private-key
# ALIPAY_PUBLIC_KEY=your-alipay-public-key

# ===========================================
# 短信配置（可选）
# ===========================================

# 腾讯云短信
# TENCENT_SMS_APP_ID=your-app-id
# TENCENT_SMS_APP_KEY=your-app-key
# TENCENT_SMS_SIGN=流痕江湖

# ===========================================
# 存储配置
# ===========================================

# 上传文件本地存储路径（备选，当 IPFS 不可用时）
UPLOAD_DIR=./uploads

# 文件大小限制（字节）
MAX_FILE_SIZE=10485760

# 允许的文件类型
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

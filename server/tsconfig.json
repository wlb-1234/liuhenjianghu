{
  "$schema": "https://schemastore.org/schemas/json/tsconfig",
  "compilerOptions": {
    "lib": ["ES2024"],
    "module": "CommonJS",
    "target": "ES2024",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmitOnError": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

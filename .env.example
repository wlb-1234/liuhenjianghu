# 流痕江湖 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================
# 数据库配置（Supabase PostgreSQL）
# ============================================
# 从 Supabase 控制台获取
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ============================================
# JWT 配置（重要：生成随机字符串）
# ============================================
# 使用以下命令生成：
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-random-64-char-secret-key-here-change-this-in-production

# ============================================
# 阿里云 OSS 配置
# ============================================
# OSS 区域：oss-cn-beijing, oss-cn-shanghai, oss-cn-hangzhou 等
OSS_REGION=oss-cn-beijing

# RAM 子账号 AccessKey（建议使用子账号，不要用主账号）
OSS_ACCESS_KEY_ID=your-access-key-id

# RAM 子账号 AccessKeySecret
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# OSS Bucket 名称
OSS_BUCKET=liuhenjianghu

# ============================================
# API 配置
# ============================================
# API 服务地址（Railway 会自动分配）
BASE_URL=https://your-railway-app.railway.app

# 服务端口（Railway 使用 5000）
PORT=5000
NODE_ENV=production

# ============================================
# 前端环境变量（在 client/.env 中配置）
# ============================================
# 注意：EXPO_PUBLIC_ 前缀的变量会暴露到前端代码中
# EXPO_PUBLIC_BACKEND_BASE_URL=https://api.liuhenjianghu.com

{
  "build": {
    "builder": "nixpacks",
    "builderConfig": {
      "name": "expo-web",
      "install": {
        "commands": ["pnpm install --frozen-lockfile || pnpm install"]
      },
      "build": {
        "commands": ["pnpm run build"]
      },
      "start": {
        "cmd": "pnpm run web:serve"
      }
    }
  }
}
